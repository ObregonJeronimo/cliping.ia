# Firebase - reemplazar con valores reales del proyecto cliping.ia
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL del backend Python (local o Railway/Fly.io)
VITE_API_URL=http://localhost:8000

# Cloudinary (backend) — el api_secret va SOLO acá, nunca en el código.
# Si esta sección está vacía, el render funciona pero no sube a la nube.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Anthropic (backend) — para el forge y el guion de Cine
ANTHROPIC_API_KEY=
