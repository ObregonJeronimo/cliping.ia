{
  "compilerOptions": {
    "lib": ["dom", "es2017"],
    "jsx": "react",
    "target": "es6",
    "module": "commonjs",
    "strict": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*", "index.jsx"]
}
